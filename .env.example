# ----------------------------------------------------------------------------
# SBI Saathi AI - Environment Variables
# Copy this file to `.env.local` and fill in your own values.
# ----------------------------------------------------------------------------

# MongoDB connection string (MongoDB Atlas or local).
# Example (Atlas): mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/sbi-saathi
MONGODB_URI="mongodb://localhost:27017/sbi-saathi"

# ---- AI Provider ----
# Choose ONE provider. The API route auto-detects which key is present.

# Google Gemini (recommended, generous free tier)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"

# OR OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Public app URL (used for absolute links / metadata)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Security secrets (REQUIRED in production) ----
# Generate strong random values, e.g.:  openssl rand -base64 48
# Each must be at least 32 characters.
JWT_SECRET=""
JWT_REFRESH_SECRET=""
CSRF_SECRET=""
